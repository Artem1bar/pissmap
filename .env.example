# PissMap NOLA — environment variables
#
# Copy to .env.local for local dev (git-ignored). NONE of these are required to
# run the map: with no DATABASE_URL the app builds, deploys, and works exactly as
# it does today — the community review UI just shows a friendly "coming soon".

# --- Reviews database (Neon Postgres via the Vercel Marketplace integration) ---
# Adding Neon to the Vercel project creates this automatically. Then locally:
#   vercel env pull .env.local && npm run db:push
DATABASE_URL=

# --- Moderation ---
# A long random string. Unlocks /admin (approve/reject reviews) via an httpOnly
# cookie. Leave blank to keep the admin page disabled.
#   openssl rand -hex 32
ADMIN_SECRET=

# --- Anti-spam ---
# A long random string used to hash reviewer IPs (sha256) for rate limiting.
# Rotating it resets everyone's rate-limit window; keep it stable in production.
#   openssl rand -hex 32
IP_SALT=

# --- Public base URL ---
# Used by permalinks, OG images, share links, and QR codes. Set it AFTER the
# domain is live and redeploy. Falls back to the Vercel production URL, then
# http://localhost:3000.
NEXT_PUBLIC_SITE_URL=
